CONFIG_DRM=y
CONFIG_DRM_BOCHS=y
CONFIG_DRM_VIRTIO_GPU=y
CONFIG_DRM_FBDEV_EMULATION=y
# Clean early-fb handoff so the boot logo doesn't freeze on efifb (see the
# aarch64 config for the full rationale). Prefer simpledrm to efifb.
CONFIG_SYSFB=y
CONFIG_SYSFB_SIMPLEFB=y
CONFIG_DRM_SIMPLEDRM=y
# CONFIG_FB_EFI is not set
