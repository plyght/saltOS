# aarch64 kernel config fragment for the self-hosted saltOS ISO, appended to
# `make defconfig` (arm64 defconfig already enables most virtio/EFI bits as
# modules; here we force the boot-critical pieces builtin so the all-in-initramfs
# system comes up with no modules to load).
#
# The whole rootfs lives in the initramfs (rdinit=/sbin/runit-init), so the
# kernel never mounts a disk at boot -- it only needs initrd + console + input.
CONFIG_BLK_DEV_INITRD=y
CONFIG_RD_GZIP=y
CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=y
CONFIG_TMPFS=y
CONFIG_PROC_FS=y
CONFIG_SYSFS=y
CONFIG_BINFMT_ELF=y
CONFIG_BINFMT_SCRIPT=y
CONFIG_TTY=y
CONFIG_VT=y
CONFIG_VT_CONSOLE=y
CONFIG_UNIX98_PTYS=y
# Serial consoles: PL011 is the QEMU `virt` UART (ttyAMA0); virtio-console
# (hvc0) is what Apple's Virtualization framework exposes. Enable both.
CONFIG_SERIAL_AMBA_PL011=y
CONFIG_SERIAL_AMBA_PL011_CONSOLE=y
CONFIG_VIRTIO_CONSOLE=y
CONFIG_HVC_DRIVER=y
# virtio transport + devices (builtin so they're up before userspace)
CONFIG_VIRTIO=y
CONFIG_VIRTIO_PCI=y
CONFIG_VIRTIO_MMIO=y
CONFIG_VIRTIO_BLK=y
CONFIG_VIRTIO_NET=y
CONFIG_VIRTIO_INPUT=y
# input for the graphical console
CONFIG_INPUT=y
CONFIG_INPUT_EVDEV=y
CONFIG_INPUT_KEYBOARD=y
CONFIG_INPUT_MOUSE=y
# framebuffer / DRM for the graphical console (and the desktop edition)
CONFIG_FB=y
CONFIG_DRM=y
CONFIG_DRM_VIRTIO_GPU=y
CONFIG_DRM_FBDEV_EMULATION=y
CONFIG_FRAMEBUFFER_CONSOLE=y
# EFI so GRUB-in-UEFI can hand off cleanly, and a live ISO can be read if needed
CONFIG_EFI=y
CONFIG_EFI_STUB=y
CONFIG_ISO9660_FS=y
CONFIG_EXT4_FS=y
CONFIG_FAT_FS=y
CONFIG_VFAT_FS=y
CONFIG_MSDOS_FS=y
CONFIG_NLS_CODEPAGE_437=y
CONFIG_NLS_ISO8859_1=y
CONFIG_PARTITION_ADVANCED=y
CONFIG_EFI_PARTITION=y
CONFIG_FS_ENCRYPTION=y
CONFIG_BLK_DEV=y
CONFIG_BLK_DEV_SD=y
CONFIG_SCSI=y
CONFIG_BLK_DEV_SR=y
